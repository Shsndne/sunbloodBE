APP_NAME=Sunblood
APP_ENV=local
APP_KEY=base64:z9GXAU62lSVFFDqRwRDm25EHxxfkoAm5mQAkDEl/uzE=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── DATABASE ─────────────────────────────────────────────
# Jika pakai MySQL (sesuaikan port & nama database Anda):
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=sunblood
DB_USERNAME=root
DB_PASSWORD=

# Uncomment baris di bawah dan comment MySQL di atas jika ingin pakai SQLite:
# DB_CONNECTION=sqlite

# ── SESSION ──────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# ── MAIL (untuk development, log saja) ───────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@sunblood.id"
MAIL_FROM_NAME="Sunblood"

# ── IP RESTRICTION ────────────────────────────────────────
# Daftar IP yang boleh akses /admin, pisahkan dengan koma
# Gunakan * untuk izinkan semua IP (mode development)
ADMIN_ALLOWED_IPS=127.0.0.1,::1

VITE_APP_NAME="${APP_NAME}"
